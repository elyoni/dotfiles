#!/usr/bin/env bash
# i3xrocks blocklet: a dedicated break timer that also pushes a notification
# to your phone via ntfy.sh when the break ends. If Garmin Connect Mobile has
# notification mirroring enabled for the ntfy app, the watch buzzes too.
#
# Left click:  set a new break (prompts for minutes + message).
# Right click: stop/clear the current break.
#
# Setup (one-time):
#   1. Install the ntfy app (https://ntfy.sh) on your phone.
#   2. Pick a private/random topic name and subscribe to it in the app.
#   3. echo "your-topic-name" > ~/.config/ntfy-topic
#   4. In Garmin Connect Mobile, enable notification mirroring for the ntfy app.

TARGET_FILE="/tmp/break_target_time"
MESSAGE_FILE="/tmp/break_message"
NOTIFIED_FILE="/tmp/break_notified"
NTFY_TOPIC_FILE="$HOME/.config/ntfy-topic"
DEFAULT_MESSAGE="Break is over, back to the computer"

BUTTON=${button:-${BLOCK_BUTTON:-}}

set_break() {
    local minutes message target

    minutes=$(zenity --entry --title "Start Break" --text "Break length (minutes):" --entry-text "5" 2>/dev/null) || return 1
    if ! [[ "$minutes" =~ ^[0-9]+$ ]] || [ "$minutes" -eq 0 ]; then
        zenity --error --text "Enter a whole number of minutes greater than 0." 2>/dev/null
        return 1
    fi

    message=$(zenity --entry --title "Start Break" --text "Message when break ends:" --entry-text "$DEFAULT_MESSAGE" 2>/dev/null) || return 1
    message="${message:-$DEFAULT_MESSAGE}"

    target=$(( $(date +%s) + minutes * 60 ))
    echo "$target" > "$TARGET_FILE"
    echo "$message" > "$MESSAGE_FILE"
    rm -f "$NOTIFIED_FILE"
}

stop_break() {
    rm -f "$TARGET_FILE" "$MESSAGE_FILE" "$NOTIFIED_FILE"
}

case "x${BUTTON}" in
    x1)
        # Run in the background so the bar doesn't block on the dialog.
        ( set_break ) &
        disown
        ;;
    x3)
        stop_break
        ;;
esac

if [ ! -f "$TARGET_FILE" ]; then
    echo "☕ --"
    echo "☕ --"
    exit 0
fi

TARGET_TIME=$(cat "$TARGET_FILE" 2>/dev/null)
if ! [[ "$TARGET_TIME" =~ ^[0-9]+$ ]]; then
    rm -f "$TARGET_FILE" "$MESSAGE_FILE" "$NOTIFIED_FILE"
    echo "☕ --"
    echo "☕ --"
    exit 0
fi

REMAINING=$((TARGET_TIME - $(date +%s)))

if [ "$REMAINING" -gt 0 ]; then
    MIN=$((REMAINING / 60))
    SEC=$((REMAINING % 60))
    printf "☕ %02d:%02d\n" "$MIN" "$SEC"
    printf "☕ %02d:%02d\n" "$MIN" "$SEC"
    echo "#91E78B"
else
    echo "☕ Time's up!"
    echo "☕ Time's up!"
    echo "#F79494"

    if [ ! -f "$NOTIFIED_FILE" ]; then
        MESSAGE=$(cat "$MESSAGE_FILE" 2>/dev/null)
        MESSAGE="${MESSAGE:-$DEFAULT_MESSAGE}"

        notify-send "Break Timer" "$MESSAGE"
        zenity --info --title "Break Timer" --text="<span font='24' weight='bold'>${MESSAGE}</span>" --width=400 2>/dev/null &

        if [ -f "$NTFY_TOPIC_FILE" ] && command -v curl >/dev/null 2>&1; then
            NTFY_TOPIC=$(cat "$NTFY_TOPIC_FILE" 2>/dev/null)
            if [ -n "$NTFY_TOPIC" ]; then
                curl -s -H "Title: Break Timer" -H "Tags: alarm_clock" -d "$MESSAGE" "https://ntfy.sh/${NTFY_TOPIC}" >/dev/null 2>&1 &
            fi
        fi

        touch "$NOTIFIED_FILE"
    fi
fi
