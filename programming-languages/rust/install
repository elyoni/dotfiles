#!/usr/bin/env bash

DIR=$(dirname "${BASH_SOURCE[0]}")
DIR=$(cd -P "$DIR" && pwd)

function install_rustup(){
    # Source the apt utility functions
    source "${DIR}/../../utils/package/apt"

    # Check if curl is available and install if needed
    if ! command -v curl &> /dev/null; then
        echo "curl is not installed. Installing curl..."
        fast_apt_install curl
    fi

    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
}

function zsh_autocompletion(){
    local zfunc_path=$HOME/.zfunc
    [ ! -d "${zfunc_path}" ] && mkdir -p "${zfunc_path}"

    # Check if cargo env file exists before sourcing
    if [ -f "$HOME/.cargo/env" ]; then
        source "$HOME/.cargo/env"
        rustup completions zsh > "${zfunc_path}"/_rustup
        rustup completions zsh cargo > "${zfunc_path}"/_cargo
    else
        echo "Warning: Rust environment not found. Skipping autocompletion setup."
    fi
}

function install()
{
    install_rustup
    zsh_autocompletion
}

function verify()
{
    :
}

function help() # Show a list of functions
{
    awk '/^function / && ! /^function _/' "$0"
}

if [ $# -eq 0 ]; then
    help
else
    "$@"
fi
