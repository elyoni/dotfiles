#!/usr/bin/env bash

DIR=$(dirname "${BASH_SOURCE[0]}")
DIR=$(cd -P "$DIR" && pwd)

function install_fzf() {
    echo 'Installing FZF... '
    if [ -e ~/.fzf ]; then
        echo 'already installed.'
    else
        git clone https://github.com/junegunn/fzf.git ~/.fzf --depth 1
        ~/.fzf/install --completion --key-bindings --no-update-rc
    fi
}

function install_packages() # Install additional package for neovim
{
    ## To connect the clipboard of the neovim and the linux
    echo ====== Install additional packages =====
    sudo apt-get update
    sudo apt-get install -y git fd-find
    # Create fd symlink with proper handling of existing files
    local fdfind_path="$(command -v fdfind)"
    if [ -e "/usr/local/bin/fd" ] || [ -L "/usr/local/bin/fd" ]; then
        echo "Removing existing fd link/file..."
        sudo rm -f "/usr/local/bin/fd"
    fi
    sudo ln -sf "${fdfind_path}" "/usr/local/bin/fd"
    echo "fd symlink created successfully"
    mkdir -p "${HOME}/.zfunc"; fd --gen-completions=zsh > ~/.zfunc/_fdfind
    echo ======== End ========
}

function verify()
{
    if [[ -f ~/.fzf/bin/fzf ]]; then

        return 0
    else
        return 1
    fi


}

function install
{
    install_packages
    install_fzf
}


function help # Show a list of functions
{
    awk '/^function / && ! /^function _/' "$0"
}

if [ $# -eq 0 ]; then
    help
else
    "$@"
fi
