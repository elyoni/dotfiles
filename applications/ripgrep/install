#!/usr/bin/env bash
#
DIR=$(dirname "${BASH_SOURCE[0]}")
DIR=$(cd -P "$DIR" && pwd)

source "${DIR}"/../../utils/package/github

function _create_config()
{
    local config_dir="${HOME}/.config/ripgrep"
    local config_file="${config_dir}/ripgreprc"

    if [[ ! -d "${config_dir}" ]]; then
        mkdir -p "${config_dir}"
    fi

    if [[ ! -f "${config_file}" ]]; then
        echo "# Ripgrep configuration file" > "${config_file}"
    fi
}

function install()
{
    local extruct_dir
    extruct_dir=$(download_latest_release 'x86_64.*linux.*tar.gz$' "BurntSushi/ripgrep")
    
    # Ensure the .local/bin directory exists
    mkdir -p "${HOME}"/.local/bin
    
    # Copy the binary with proper filename
    cp "${extruct_dir}"/rg "${HOME}"/.local/bin/rg
    rm -rf "${extruct_dir}"

    # Ensure .zfunc directory exists
    mkdir -p "${HOME}"/.zfunc
    "${HOME}"/.local/bin/rg --generate=complete-zsh > "${HOME}"/.zfunc/_rg
}

function verify()
{
    # Check if rg exists in .local/bin (where we installed it)
    if [[ -f "${HOME}/.local/bin/rg" ]]; then
        return 0
    else
        return 1
    fi
}

function help() # Show a list of functions
{
    awk '/^function / && ! /^function _/' "$0"
}

if [ $# -eq 0 ]; then
    help
else
    "$@"
fi
