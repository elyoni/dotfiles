#!/usr/bin/env bash

# Usage:
#   ./git-site [--update] [--remote remote_name] [path[:L<line>] | --file path[:line]]
#   ./git-site mr [--me] [--all] [--state opened|merged|closed] [--scope all|assigned_to_me|created_by_me]
#   ./git-site pipeline
#   ./git-site pipeline-new [--var NAME=VALUE ...]
#   ./git-site pipeline-run [--var NAME=VALUE ...]

UPDATE=0
REMOTE="origin"
FILE_LINE=""
FILE=""
LINE=""
MODE="normal"  # normal, mr, pipeline, pipeline-new, pipeline-run
MR_ME=0
MR_ALL=0
MR_STATE="opened"
MR_SCOPE="all"
PIPELINE_VARS=()

# --- Parse args ---
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)
      cat << EOF
Usage: git-site [options]
       git-site mr [options]
       git-site pipeline
       git-site pipeline-new [options]
       git-site pipeline-run [options]

Opens the current git repository in the browser at the hosting service (GitHub, GitLab, etc.)

Options:
  -h, --help               Show this help message
  --update                 Update remote refs before opening
  --remote REMOTE_NAME     Use specified remote name (default: origin)
  --file PATH[:LINE]       Open specific file, optionally at line number
  PATH[:LINE]              Positional shorthand for --file
                          Line formats: :42  :L42  :10:20  :L10-L20

Merge Request Options (git-site mr):
  --me                     Filter merge requests by current user
  --all                    Disable branch filter (show all branches)
  --state STATE            Filter by state: opened, merged, or closed (default: opened)
  --scope SCOPE            Filter by scope: all, assigned_to_me, or created_by_me (default: all)

Pipeline Options:
  git-site pipeline        Open pipelines list for current branch
  git-site pipeline-new    Open "Run pipeline" web page (can pre-fill variables)
  git-site pipeline-run    Trigger a new pipeline via glab API (requires glab)

  --var NAME=VALUE         Set a pipeline variable (repeatable, for pipeline-new and pipeline-run)
                           Variable names are autocompleted from .gitlab-ci.yml

Examples:
  git-site                           # Open current branch
  git-site src/main.js               # Open file
  git-site src/main.js:L25          # Open file at line 25
  git-site src/main.js:L10-L20      # Open file at line range
  git-site --file src/main.js:25    # Same with explicit flag
  git-site --remote upstream         # Use 'upstream' remote instead of 'origin'
  git-site --update README.md       # Update refs and open README
  git-site mr                        # Open MRs filtered by current branch
  git-site mr --me                   # Open MRs filtered by branch and current user
  git-site mr --me --all             # Open MRs filtered by current user (all branches)
  git-site mr --all                  # Open MRs page with no filters
  git-site mr --me --state merged    # Open merged MRs by current user on this branch
  git-site pipeline                  # Open pipelines list for current branch
  git-site pipeline-new              # Open "Run pipeline" page for current branch
  git-site pipeline-new --var ENV=prod   # Pre-fill a variable
  git-site pipeline-new --var ENV=prod --var DEBUG=1  # Pre-fill multiple variables
  git-site pipeline-run              # Trigger a pipeline for current branch via glab
  git-site pipeline-run --var ENV=prod   # Trigger with a variable
EOF
      exit 0
      ;;
    mr) MODE="mr" ;;
    pipeline) MODE="pipeline" ;;
    pipeline-new) MODE="pipeline-new" ;;
    pipeline-run) MODE="pipeline-run" ;;
    --update) UPDATE=1 ;;
    --remote) shift; REMOTE="$1" ;;
    --file) shift; FILE_LINE="$1" ;;
    --me) MR_ME=1 ;;
    --all) MR_ALL=1 ;;
    --state) shift; MR_STATE="$1" ;;
    --scope) shift; MR_SCOPE="$1" ;;
    --var) shift; PIPELINE_VARS+=("$1") ;;
    *)
      if [ -z "$FILE_LINE" ] && [ "$MODE" = "normal" ]; then
        FILE_LINE="$1"
      fi
      ;;
  esac
  shift
done

# --- Optional: Update remote refs ---
[ "$UPDATE" -eq 1 ] && git fetch --prune "$REMOTE" >/dev/null 2>&1

# --- Get current branch (used by both normal and MR mode) ---
current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo master)
if ! git show-ref --quiet "refs/remotes/$REMOTE/$current_branch"; then
  current_branch=master
fi

# --- Skip file/line logic if in MR or pipeline mode ---
if [ "$MODE" = "normal" ]; then
  # --- Extract file and line range ---
  # Supported formats: path:42  path:L42  path:10:20  path:L10:L20  path:L10-L20
  if echo "$FILE_LINE" | grep -q ":"; then
    FILE="${FILE_LINE%%:*}"          # everything before first colon
    LINE_SPEC="${FILE_LINE#*:}"      # everything after first colon
    LINE_SPEC="${LINE_SPEC#L}"       # strip optional leading L (handles :L42)
    if echo "$LINE_SPEC" | grep -q ":"; then
      # Colon-separated range: 10:20 or L10:L20
      start="${LINE_SPEC%%:*}"; start="${start#L}"
      end="${LINE_SPEC##*:}"; end="${end#L}"
      line_anchor="#L${start}-L${end}"
    elif echo "$LINE_SPEC" | grep -qE "^[0-9]+-"; then
      # Dash-separated range: 10-20 or 10-L20 (GitHub/GitLab copy format)
      start="${LINE_SPEC%%-*}"
      end="${LINE_SPEC##*-}"; end="${end#L}"
      line_anchor="#L${start}-L${end}"
    else
      line_anchor="#L${LINE_SPEC}"
    fi
  else
    FILE="$FILE_LINE"
    line_anchor=""
  fi
  
  # --- Resolve file path relative to repo root ---
  repo_root=$(git rev-parse --show-toplevel)
  if [ -n "$FILE" ]; then
    rel_path=$(realpath --relative-to="$repo_root" "$FILE")
    file_part="/$rel_path"
  else
    file_part=""
  fi
fi

# --- Normalize GitHub/GitLab remote URL to web format ---
remote_url=$(git config --get "remote.$REMOTE.url")
host_path=$(echo "$remote_url" | sed -E 's#^(ssh://)?git@([^:/]+)(:[0-9]+)?[:/]([^/]+/.+)\.git$#https://\2/\4#')

# --- URL-encode a string (pure bash, no external deps) ---
_urlencode() {
  local string="$1" encoded="" pos c
  for (( pos=0; pos<${#string}; pos++ )); do
    c="${string:$pos:1}"
    case "$c" in
      [-_.~a-zA-Z0-9]) encoded+="$c" ;;
      *) printf -v c '%%%02X' "'$c"; encoded+="$c" ;;
    esac
  done
  printf '%s' "$encoded"
}

# --- Build final URL or execute command ---
if [ "$MODE" = "mr" ]; then
  # Merge request mode
  url="${host_path}/-/merge_requests"

  # Build query parameters
  query_params=()
  query_params+=("scope=${MR_SCOPE}")
  query_params+=("state=${MR_STATE}")
  if [ $MR_ALL -eq 0 ]; then
    query_params+=("source_branch=${current_branch}")
  fi

  # Add author_username if --me flag is set
  if [ $MR_ME -eq 1 ]; then
    username=""
    # Try to get username from glab
    if command -v glab >/dev/null 2>&1; then
      username=$(glab api user 2>/dev/null | grep -o '"username":"[^"]*"' | cut -d'"' -f4)
    fi

    # Fallback to git config user.name
    if [ -z "$username" ]; then
      username=$(git config user.name 2>/dev/null)
    fi

    # Fallback to environment variable
    if [ -z "$username" ]; then
      username="${GITLAB_USERNAME:-${USER}}"
    fi

    if [ -n "$username" ]; then
      query_params+=("author_username=${username}")
    fi
  fi

  # Join query parameters
  query_string=$(IFS='&'; echo "${query_params[*]}")
  url="${url}?${query_string}"
elif [ "$MODE" = "pipeline" ]; then
  # Open pipelines list filtered by current branch
  url="${host_path}/-/pipelines?ref=${current_branch}"
elif [ "$MODE" = "pipeline-new" ]; then
  # Open "Run pipeline" web page with optional pre-filled variables
  url="${host_path}/-/pipelines/new?ref=${current_branch}"
  for var_pair in "${PIPELINE_VARS[@]}"; do
    var_name="${var_pair%%=*}"
    var_value="${var_pair#*=}"
    url="${url}&var[$(_urlencode "$var_name")]=$(_urlencode "$var_value")"
  done
elif [ "$MODE" = "pipeline-run" ]; then
  # Trigger pipeline via glab API
  if ! command -v glab >/dev/null 2>&1; then
    echo "Error: glab is required for pipeline-run" >&2
    exit 1
  fi
  cmd=(glab ci run --branch "$current_branch")
  for var_pair in "${PIPELINE_VARS[@]}"; do
    cmd+=(--variables "$var_pair")
  done
  "${cmd[@]}"
  exit 0
else
  # Normal file/branch mode
  url="${host_path}/blob/${current_branch}${file_part}${line_anchor}"
fi

# --- Output or open URL ---
if [ -n "$SSH_CONNECTION" ]; then
  echo "You are on a remote device. The project URL is: $url"
  if command -v xclip >/dev/null; then
    echo "$url" | xclip -selection clipboard
    echo "   URL copied to clipboard."
  fi
else
  if command -v xdg-open >/dev/null; then
    xdg-open "$url" >/dev/null 2>&1
  else
    echo "Failed to open browser. The project URL is: $url"
  fi
fi
