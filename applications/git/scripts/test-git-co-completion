#!/usr/bin/env zsh

# Test script for git co completion: sourcing, no errors, and completion behavior.
# Run after compinit so _git and _git_checkout exist. Verifies "git co <TAB>" offers branches.

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

function test_pass() {
    echo -e "${GREEN}✓${NC} $1"
}

function test_fail() {
    echo -e "${RED}✗${NC} $1"
    [[ -n "$2" ]] && echo "$2"
    exit 1
}

function test_info() {
    echo -e "${YELLOW}→${NC} $1"
}

# Paths (allow override via env for different installs)
DOTFILES_ROOT="${DOTFILES_ROOT:-$HOME/.dotfiles}"
FUNCTIONS_FILE="${DOTFILES_ROOT}/applications/zsh/zsh_config/functions.zsh"
WRAPPER_FILE="${DOTFILES_ROOT}/applications/zsh/zsh_config/git_wrapper.zsh"
COMPLETION_FILE="${DOTFILES_ROOT}/applications/zsh/zsh_config/git_completion.zsh"

echo "Testing git co completion..."
echo ""

[[ ! -f "$FUNCTIONS_FILE" ]] && test_fail "functions.zsh not found at $FUNCTIONS_FILE"
[[ ! -f "$COMPLETION_FILE" ]] && test_fail "git_completion.zsh not found at $COMPLETION_FILE"

# Initialize completion so _git and _git_checkout are available, then load our config
# Source in current shell so _git_co and _git_co_impl are defined for later tests
test_info "Initializing completion and loading config"
autoload -Uz compinit
compinit -C 2>/dev/null || true
source "$FUNCTIONS_FILE" 2>/dev/null || true
[[ -f "$WRAPPER_FILE" ]] && source "$WRAPPER_FILE" 2>/dev/null || true
source "$COMPLETION_FILE" 2>/dev/null || true
test_pass "compinit and config loaded"
echo ""

# Test 1: Completion file provided _git_co (for completion)
test_info "Test 1: _git_co completion function exists"
if (( $+functions[_git_co] )); then
    if (( $+functions[_git_checkout] )); then
        errors=$(_git_co 2>&1)
        if echo "$errors" | grep -qE "(compstate|comptags|comptry|assignment to invalid)"; then
            test_fail "_git_co() produces completion errors when called" "$errors"
        fi
        test_pass "_git_co() exists and doesn't error when called outside completion"
    else
        test_pass "_git_co() is defined (full git completion not loaded in this env)"
    fi
else
    test_fail "_git_co() function not found"
fi
echo ""

# Test 2: git co execution uses _git_co_impl (wrapper calls it)
test_info "Test 2: git co execution uses _git_co_impl"
if (( $+functions[_git_co_impl] )); then
    test_pass "_git_co_impl() is defined for execution"
else
    test_fail "_git_co_impl() not found (git co behavior will not work)"
fi
echo ""

# Test 3: git() wrapper (skip if not a function, e.g. not loaded)
test_info "Test 3: git() wrapper"
if (( $+functions[git] )); then
    out=$(git --version 2>&1)
    if echo "$out" | grep -qE "(compstate|comptags|comptry|assignment to invalid)"; then
        test_fail "git() wrapper produced completion errors" "$out"
    fi
    test_pass "git() wrapper works and doesn't break normal git"
else
    test_info "git() wrapper not loaded (skipping)"
    test_pass "skipped (git wrapper not loaded)"
fi
echo ""

# Test 4: _git_subcommands contains co
test_info "Test 4: _git_subcommands contains co"
if (( $+_git_subcommands )) && [[ -n "${_git_subcommands[(r)co]}" ]]; then
    test_pass "_git_subcommands contains 'co'"
else
    test_fail "_git_subcommands missing 'co'"
fi
echo ""

# Test 5: In a temp repo, completion wiring and behavior
test_info "Test 5: Completion in a git repo (temp repo)"
tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/git-co-test-$$")
mkdir -p "$tmpdir"
cd "$tmpdir" || exit 1
command git init -q 2>/dev/null || true
command git config user.email "test@test.com" 2>/dev/null || true
command git config user.name "Test" 2>/dev/null || true
command git checkout -b main -q 2>/dev/null || true
command git commit --allow-empty -m "init" --no-gpg-sign -q 2>/dev/null || true

# Ensure we're in a repo and completion still has co
if command git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    if (( $+_git_subcommands )) && [[ -n "${_git_subcommands[(r)co]}" ]]; then
        test_pass "In repo: _git_subcommands still contains 'co'"
    else
        test_fail "In repo: _git_subcommands missing 'co'"
    fi
else
    test_pass "Temp repo created (completion wiring not re-tested in repo)"
fi
cd - >/dev/null 2>&1
rm -rf "$tmpdir"
echo ""

# Test 6: In repo, _git_co (completion) does not crash when invoked (completion context not full)
test_info "Test 6: _git_co completion in repo (no crash)"
if (( $+functions[_git_checkout] )); then
    tmpdir2=$(mktemp -d 2>/dev/null || echo "/tmp/git-co-t2-$$")
    mkdir -p "$tmpdir2"
    cd "$tmpdir2" || exit 1
    command git init -q 2>/dev/null || true
    command git config user.email "test@test.com" 2>/dev/null || true
    command git config user.name "Test" 2>/dev/null || true
    command git checkout -b main -q 2>/dev/null || true
    command git commit --allow-empty -m "init" --no-gpg-sign -q 2>/dev/null || true
    crash=$(_git_co 2>&1)
    if echo "$crash" | grep -qE "compadd.*only be called from completion"; then
        test_pass "In repo: _git_co (completion) runs (compadd restriction expected outside widget)"
    elif echo "$crash" | grep -qE "(compstate|comptags|comptry|assignment to invalid)"; then
        test_fail "In repo: _git_co produced completion errors" "$crash"
    else
        test_pass "In repo: _git_co (completion) runs without error"
    fi
    cd - >/dev/null 2>&1
    rm -rf "$tmpdir2"
else
    test_pass "In repo: skipped (full git completion not loaded)"
fi
echo ""

echo -e "${GREEN}All completion tests passed!${NC}"
