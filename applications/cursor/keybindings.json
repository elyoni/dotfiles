// Place your key bindings in this file to override the defaults
[
    {
        "key": "ctrl+i",
        "command": "composerMode.agent"
    },
    // Ctrl+N - Toggle sidebar (editor only)
    {
        "key": "ctrl+n",
        "command": "-workbench.action.files.newUntitledFile"
    },
    {
        "key": "ctrl+n",
        "command": "workbench.view.explorer",
        "when": "!explorerViewletVisible && editorTextFocus"
    },
    {
        "key": "ctrl+n",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "explorerViewletVisible && editorTextFocus"
    },
    // Ctrl+[ and Ctrl+] - Navigate between editor tabs
    {
        "key": "ctrl+[",
        "command": "workbench.action.previousEditor",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+]",
        "command": "workbench.action.nextEditor",
        "when": "editorTextFocus"
    },
    // Ctrl+W - Close current file (editor only)
    {
        "key": "ctrl+w",
        "command": "workbench.action.closeActiveEditor",
        "when": "editorTextFocus"
    },
    // Ctrl+Shift+L - Toggle between editor and chat
    {
        "key": "ctrl+shift+l",
        "command": "aichat.newchataction",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+shift+l",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "!editorTextFocus"
    },
    // Ctrl+T - Open new chat (when in chat side)
    {
        "key": "ctrl+t",
        "command": "composer.createNewWithPrevContext",
        "when": "!editorTextFocus"
    },
    // Ctrl+Shift+Z - Toggle zen mode (works everywhere)
    {
        "key": "ctrl+shift+z",
        "command": "workbench.action.toggleZenMode"
    },
    // ,fg - Find in files (ripgrep search in project)
    {
        "key": ", f g",
        "command": "workbench.action.findInFiles",
        "when": "editorTextFocus && neovim.mode == 'normal'"
    },
    // Existing neovim keybinding
    {
        "key": ", f b",
        "command": "vscode-neovim.send",
        "when": "editorTextFocus && neovim.mode == 'normal'",
        "args": ",fn"
    },
    // Open current file in external Neovim (project directory)
    // Option 1: Using task (requires .vscode/tasks.json in workspace)
    {
        "key": "ctrl+shift+n",
        "command": "workbench.action.tasks.runTask",
        "args": "Open Current File in Neovim (Project Directory)"
    },
    // Option 2: Direct terminal command (works without tasks.json)
    {
        "key": "ctrl+shift+alt+n",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "cd ${workspaceFolder} && ${env:HOME}/.dotfiles/scripts/nvim-open.sh '${file}'\r"
        },
        "when": "editorTextFocus && terminalProcessSupported"
    }
]
